#!/bin/bash

# fig-start ‚Äî Launch Figma CLI + AI Agent (Gemini, Claude, Qwen Code)
# Connects to Figma, lets you pick an open file, then launches your AI agent.
# Usage:
#   fig-start              ‚Üí Yolo Mode (default) with file selector
#   fig-start --safe       ‚Üí Safe Mode (plugin-based, no patching)
#   fig-start --here       ‚Üí Stay in current directory (don't cd to repo)
#   fig-start --agent NAME ‚Üí Select agent (gemini, claude, qwencode)
#   fig-start --setup      ‚Üí set/change the figma-cli repo path

CONFIG_DIR="$HOME/.figma-cli"
CONFIG_FILE="$CONFIG_DIR/config.json"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ‚îÄ‚îÄ Config helpers ‚îÄ‚îÄ

get_daemon_token() {
    local token_file="$HOME/.figma-ds-cli/.daemon-token"
    if [ -f "$token_file" ]; then
        cat "$token_file" 2>/dev/null
    fi
}

get_repo_path() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('repoPath',''))" 2>/dev/null
    fi
}

save_repo_path() {
    mkdir -p "$CONFIG_DIR"
    python3 -c "
import json, os
path = '$CONFIG_FILE'
cfg = {}
if os.path.exists(path):
    with open(path) as f: cfg = json.load(f)
cfg['repoPath'] = '$1'
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
"
}

get_default_agent() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('defaultAgent','gemini'))" 2>/dev/null
    else
        echo "gemini"
    fi
}

save_default_agent() {
    mkdir -p "$CONFIG_DIR"
    python3 -c "
import json, os
path = '$CONFIG_FILE'
cfg = {}
if os.path.exists(path):
    with open(path) as f: cfg = json.load(f)
cfg['defaultAgent'] = '$1'
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
"
}

normalize_agent() {
    case "$1" in
        qwini|qwen|qwen-code)
            printf 'qwencode'
            ;;
        *)
            printf '%s' "$1"
            ;;
    esac
}

resolve_agent_command() {
    local agent
    agent=$(normalize_agent "$1")
    case "$agent" in
        qwencode)
            printf 'qwen'
            ;;
        *)
            printf '%s' "$agent"
            ;;
    esac
}

resolve_agent_executable() {
    local cmd
    cmd=$(resolve_agent_command "$1")

    if command -v "$cmd" >/dev/null 2>&1; then
        command -v "$cmd"
        return
    fi

    local npm_bin
    npm_bin=$(npm bin -g 2>/dev/null)
    if [ -n "$npm_bin" ]; then
        for ext in "" ".cmd" ".exe"; do
            if [ -x "$npm_bin/$cmd$ext" ]; then
                printf '%s' "$npm_bin/$cmd$ext"
                return
            fi
        done
    fi

    printf '%s' "$cmd"
}

resolve_npm_package() {
    local agent
    agent=$(normalize_agent "$1")
    case "$agent" in
        gemini)
            printf '@google/generative-ai'
            ;;
        claude)
            printf '@anthropic-ai/sdk'
            ;;
        qwencode)
            printf '@qwen-code/qwen-code'
            ;;
        *)
            printf ''
            ;;
    esac
}

check_agent_installed() {
    local package
    package=$(resolve_npm_package "$1")
    if [ -n "$package" ] && npm list -g "$package" >/dev/null 2>&1; then
        return 0
    fi

    local executable
    executable=$(resolve_agent_executable "$1")
    if [ -x "$executable" ] || command -v "$executable" >/dev/null 2>&1; then
        return 0
    fi

    return 1
}

get_available_agents() {
    local agents=("gemini" "claude" "qwencode")
    local available=()
    for agent in "${agents[@]}"; do
        if check_agent_installed "$agent"; then
            available+=("$agent")
        fi
    done
    printf '%s\n' "${available[@]}"
}

# ‚îÄ‚îÄ Arrow-key selector (same UX as fancoolo-start) ‚îÄ‚îÄ

select_file() {
    local options=("$@")
    local count=${#options[@]}
    local selected=0

    tput civis > /dev/tty 2>/dev/null
    trap 'tput cnorm > /dev/tty 2>/dev/null' EXIT

    draw_menu() {
        if [ "$1" = "redraw" ]; then
            printf "\033[%dA" "$((count + 2))" > /dev/tty
        fi

        printf "${BOLD}Select a Figma file (‚Üë‚Üì arrows, Enter to confirm):${NC}\n" > /dev/tty
        printf "\n" > /dev/tty
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$selected" ]; then
                printf "  ${GREEN}‚ñ∏ %s${NC}\n" "${options[$i]}" > /dev/tty
            else
                printf "    %s\n" "${options[$i]}" > /dev/tty
            fi
        done
    }

    draw_menu "first"

    while true; do
        IFS= read -rsn1 key < /dev/tty

        case "$key" in
            $'\x1b')
                read -rsn2 seq < /dev/tty
                case "$seq" in
                    '[A')
                        ((selected--))
                        [ "$selected" -lt 0 ] && selected=$((count - 1))
                        ;;
                    '[B')
                        ((selected++))
                        [ "$selected" -ge "$count" ] && selected=0
                        ;;
                esac
                ;;
            ''|$'\n'|$'\r')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                printf '%s' "${options[$selected]}"
                return
                ;;
            'q')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                return
                ;;
        esac

        draw_menu "redraw"
    done
}

# ‚îÄ‚îÄ Main ‚îÄ‚îÄ

# Handle flags
SAFE_MODE=false
STAY_HERE=false
AGENT_OVERRIDE=""
SETUP_MODE=false

while [ $# -gt 0 ]; do
    case "$1" in
        --safe)
            SAFE_MODE=true
            shift
            ;;
        --here)
            STAY_HERE=true
            shift
            ;;
        --setup)
            SETUP_MODE=true
            shift
            ;;
        --agent)
            shift
            if [ $# -gt 0 ]; then
                AGENT_OVERRIDE="$1"
                shift
            fi
            ;;
        --agent=*)
            AGENT_OVERRIDE="${1#*=}"
            shift
            ;;
        *)
            shift
            ;;
    esac
done

if [ "$SETUP_MODE" = true ]; then
    printf "${BOLD}Enter the path to your figma-cli repo:${NC} "
    read -r repo_path < /dev/tty
    repo_path="${repo_path/#\~/$HOME}"
    if [ ! -f "$repo_path/src/index.js" ]; then
        echo -e "${RED}Not a valid figma-cli repo:${NC} $repo_path"
        exit 1
    fi
    save_repo_path "$repo_path"
    echo -e "${GREEN}Saved.${NC} Run ${BOLD}fig-start${NC} to begin."
    exit 0
fi

# Resolve repo path
REPO_PATH=$(get_repo_path)

if [ -z "$REPO_PATH" ] || [ ! -d "$REPO_PATH" ]; then
    # Try to find it relative to this script
    SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    if [ -f "$SCRIPT_DIR/src/index.js" ]; then
        REPO_PATH="$SCRIPT_DIR"
        save_repo_path "$REPO_PATH"
    else
        echo -e "${YELLOW}figma-cli repo not configured.${NC}"
        printf "${BOLD}Enter the path to your figma-cli repo:${NC} "
        read -r REPO_PATH < /dev/tty
        REPO_PATH="${REPO_PATH/#\~/$HOME}"
        if [ ! -f "$REPO_PATH/src/index.js" ]; then
            echo -e "${RED}Not a valid figma-cli repo:${NC} $REPO_PATH"
            exit 1
        fi
        save_repo_path "$REPO_PATH"
    fi
fi

CLI="$REPO_PATH/src/index.js"

echo ""
if [ "$SAFE_MODE" = true ]; then
    echo -e "${BOLD}  fig-start${NC} ${DIM}‚Äî Figma CLI launcher (Safe Mode)${NC}"
else
    echo -e "${BOLD}  fig-start${NC} ${DIM}‚Äî Figma CLI launcher${NC}"
fi
echo ""

# Resolve agent to use
if [ -n "$AGENT_OVERRIDE" ]; then
    AGENT=$(normalize_agent "$AGENT_OVERRIDE")
else
    AGENT=$(normalize_agent "$(get_default_agent)")
fi

# Verify agent is available
if ! check_agent_installed "$AGENT"; then
    AVAILABLE=($(get_available_agents))
    if [ ${#AVAILABLE[@]} -eq 0 ]; then
        echo -e "${RED}‚úó No AI agents installed.${NC}"
        echo ""
        echo "Install one:"
        echo "  ‚Ä¢ Gemini:  npm install -g @google/generative-ai"
        echo "  ‚Ä¢ Claude:  npm install -g @anthropic-ai/sdk"
        echo "  ‚Ä¢ Qwencode: npm install -g @qwen-code/qwen-code"
        echo ""
        exit 1
    elif [ ${#AVAILABLE[@]} -eq 1 ]; then
        AGENT="${AVAILABLE[0]}"
        echo -e "${YELLOW}‚öÝ ${NC}${AGENT} not available, falling back to: ${AGENT}"
    else
        echo -e "${YELLOW}‚öÝ Configured agent '${AGENT}' not available.${NC}"
        echo "Available: ${AVAILABLE[@]}"
        echo ""
        PS3="Select an agent: "
        select AGENT in "${AVAILABLE[@]}"; do
            if [ -n "$AGENT" ]; then
                save_default_agent "$AGENT"
                break
            fi
        done
    fi
fi

echo -e "  ${GREEN}Using agent: ${AGENT}${NC}"

# Step 1: Check if Figma is running, start if not
if ! pgrep -x "Figma" > /dev/null 2>&1; then
    echo -e "  ${YELLOW}Starting Figma...${NC}"
    open -a Figma
    sleep 3
fi

# Step 2: Connect to Figma
if [ "$SAFE_MODE" = true ]; then
    # ‚îÄ‚îÄ Safe Mode: plugin-based connection ‚îÄ‚îÄ
    # Run connect --safe interactively so user sees plugin setup instructions
    echo -e "  ${BOLD}üîí Safe Mode${NC} ‚Äî plugin-based, no patching required"
    echo ""
    node "$CLI" connect --safe
    if [ $? -ne 0 ]; then
        echo -e "  ${RED}Connection failed.${NC}"
        exit 1
    fi
    echo ""

    # Skip file selector (Safe Mode only sees the active file via plugin)
    echo -e "  ${GREEN}Launching ${AGENT}...${NC}"
    echo ""
    # Launch through Node.js which handles cross-platform path resolution
    exec node "$CLI" launch-agent "$AGENT"
else
    # ‚îÄ‚îÄ Yolo Mode: CDP-based connection ‚îÄ‚îÄ
    # Check if CDP is already accessible (avoid killing/restarting Figma)
    CDP_OK=false
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:9222/json 2>/dev/null | grep -q "200"; then
        CDP_OK=true
    fi

    if [ "$CDP_OK" = true ]; then
        # Figma is already accessible ‚Äî just ensure daemon is running
        DAEMON_OK=false
        DAEMON_TOKEN=$(get_daemon_token)
        if [ -n "$DAEMON_TOKEN" ]; then
            if curl -s -o /dev/null -w "%{http_code}" -H "X-Daemon-Token: $DAEMON_TOKEN" http://localhost:3456/health 2>/dev/null | grep -q "200"; then
                DAEMON_OK=true
            fi
        fi
        if [ "$DAEMON_OK" = false ]; then
            echo -e "  Starting daemon..."
            node "$CLI" daemon restart > /dev/null 2>&1
            sleep 1
        fi
        echo -e "  ${GREEN}‚úì Connected${NC}"
    else
        # Not accessible ‚Äî run full connect (will kill + restart Figma)
        echo -e "  Connecting to Figma..."
        CONNECT_OUT=$(node "$CLI" connect 2>&1)
        if [ $? -ne 0 ]; then
            echo -e "  ${RED}Connection failed:${NC}"
            echo "$CONNECT_OUT"
            echo ""
            echo -e "  ${YELLOW}Tip:${NC} Try ${BOLD}fig-start --safe${NC} if patching fails."
            exit 1
        fi
        echo -e "  ${GREEN}‚úì Connected${NC}"
        # Wait for Figma to fully restore all tabs after restart
        sleep 3
    fi

    # Step 3: List open files and let user pick
    echo -e "  Loading open files..."
    FILES_JSON=$(node "$CLI" files 2>/dev/null)

    if [ -z "$FILES_JSON" ] || echo "$FILES_JSON" | grep -q '"error"'; then
        echo -e "  ${RED}Could not list files.${NC} Is Figma open with a file?"
        exit 1
    fi

    # Parse file titles
    FILE_TITLES=()
    while IFS= read -r title; do
        FILE_TITLES+=("$title")
    done < <(echo "$FILES_JSON" | python3 -c "
import json, sys
files = json.load(sys.stdin)
for f in files:
    t = f.get('title', 'Untitled')
    # Clean up Figma title format (remove ' ‚Äì Figma' suffix)
    t = t.replace(' ‚Äì Figma', '').replace(' - Figma', '')
    print(t)
" 2>/dev/null)

    if [ ${#FILE_TITLES[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}No Figma files detected.${NC} Open a file in Figma first."
        echo ""
        echo -e "  Launching ${AGENT}...${NC}"
        echo ""
        # Launch through Node.js which handles cross-platform path resolution
        exec node "$CLI" launch-agent "$AGENT"
    fi

    echo ""
    SELECTED_TITLE=$(select_file "${FILE_TITLES[@]}")
    if [ -z "$SELECTED_TITLE" ]; then
        echo "  Cancelled."
        exit 0
    fi

    echo -e "  ${GREEN}‚úì File: ${BOLD}${SELECTED_TITLE}${NC}"
    echo ""

    # Step 4: Launch AI Agent
    echo -e "  ${GREEN}Launching ${AGENT}...${NC}"    
    echo ""
    # Launch through Node.js which handles cross-platform path resolution
    exec node "$CLI" launch-agent "$AGENT"
fi
